<Window x:Class="lab4_5.Servises"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab4_5"
        mc:Ignorable="d"
        Title="MainWindow" WindowState="Maximized" WindowStartupLocation="CenterScreen"
        Cursor="{DynamicResource Kursor}">
    <Window.Resources>
        <Cursor x:Key="Kursor">C:\labi_2kurs_2_sem\OOP\lab4_5\Normal Select.cur</Cursor>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD19292" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
    </Window.Resources>
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        
        <!-- Шапка с логотипом и названием -->
        <StackPanel Grid.Row="0" Background="#007ACC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Source="C:\labi_2kurs_2_sem\OOP\lab4_5\3840714.png" Width="40" Height="30" Margin="5"/>
                <TextBlock Text="Medical Center" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0, 10, 14, 14" Grid.Column="1" />
                <Button x:Name="LanguageButton" Content="{DynamicResource ChangeLanguageButtonText}" Foreground="White" Background="Transparent" BorderBrush="Transparent" Margin="5" Padding="5" Grid.Column="2" HorizontalAlignment="Right" Click="LanguageButton_Click"/>
            </Grid>
        </StackPanel>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4.7*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Боковая панель навигации -->
            <StackPanel Grid.Column="0" Background="#EFEFEF">
                <Button Content="{DynamicResource MainPageButtonText}" Style="{StaticResource MenuButtonStyle}" Name="MainPage" />
                <Button Content="{DynamicResource ServicesButtonText}" Style="{StaticResource MenuButtonStyle}" Name="ServPage"/>
                <Button Content="{DynamicResource AdminPanelButtonText}" Style="{StaticResource MenuButtonStyle}" Name="AdminPage"/>
            </StackPanel>

            <!-- Основной контент -->
            <Grid Grid.Column="1">
                <ScrollViewer Margin="0,0,-100,0">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                        <TextBlock Text="{DynamicResource OurProcedures}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox Width="150" Name="SearchTextBox" />
                            <Button Content="{DynamicResource SearchText}" Width="80" Margin="10,0,0,0" Click="Button_Click_1" />
                        </StackPanel>
                        <StackPanel Name="ServicesStackPanel"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Панель фильтрации -->
            <StackPanel Grid.Column="2" Background="#EFEFEF" Margin="99,0,0,0">
                <StackPanel Margin="10">
                    <TextBlock Text="{DynamicResource Filters}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />

                    <!-- Адаптивная панель фильтрации -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Text="{DynamicResource PriceText}" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{DynamicResource FromText}" />
                            <TextBox Width="70" Name="MinPriceTextBox" HorizontalAlignment="Stretch" />
                            <TextBlock Text="{DynamicResource ToText}" Margin="10,0,0,0" />
                            <TextBox Width="70" Name="MaxPriceTextBox" HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <TextBlock Grid.Row="2" Text="{DynamicResource CategoryText}" />
                        <ComboBox Grid.Row="3" Width="150" Name="CategoryComboBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="{DynamicResource All}" IsSelected="True" />
                            <ComboBoxItem Content="{DynamicResource Cargiologia}" />
                            <ComboBoxItem Content="{DynamicResource Andocrinologi}" />
                            <ComboBoxItem Content="{DynamicResource Therapy}" />
                        </ComboBox>
                        <Button Grid.Row="4" Content="{DynamicResource ApplyText}" Width="80" HorizontalAlignment="Stretch" Margin="0,10,0,0" Name="primButton" Click="primButton_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>