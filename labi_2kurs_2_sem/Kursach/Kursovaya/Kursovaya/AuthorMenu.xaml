<Window x:Class="Kursovaya.AuthorMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kursovaya"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" 
        Title="AuthorMenu" Height="1080" Width="1920">
    <Window.Resources>
        <FontFamily x:Key="Montserrat">/Montserrat_font/#Montserrat</FontFamily>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="1" Color="#C7CFE2"/>
                    <GradientStop Offset="0" Color="#7686AB"/>
                </LinearGradientBrush>
            </Grid.Background>

            <TextBlock Text="YOUR PICTURES" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{StaticResource Montserrat}" FontSize="96" FontWeight="Bold" Margin="0,48,0,48" Foreground="#FF22304F"/>
            <Button Click="Back_click" HorizontalAlignment="Left" VerticalAlignment="Top"  Width="60" Height="60" Background="{x:Null}" Margin="100,80,00,0" Foreground="{x:Null}" BorderBrush="{x:Null}">
                <Image Source="C:\labi_2kurs_2_sem\Kursach\Kursovaya\Kursovaya\images\back.png" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <Button Click="Create_Image_Click" HorizontalAlignment="Right" VerticalAlignment="Top"  Width="50" Height="50" Background="{x:Null}" Margin="0,85,200,0" Foreground="{x:Null}" BorderBrush="{x:Null}">
                <Image Source="C:\labi_2kurs_2_sem\Kursach\Kursovaya\Kursovaya\images\plus.png" Width="45" Height="45" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <Button Click="Refresh_Click" HorizontalAlignment="Right" VerticalAlignment="Top"  Width="60" Height="60" Background="{x:Null}" Margin="0,80,300,0" Foreground="{x:Null}" BorderBrush="{x:Null}">
                <Image Source="C:\labi_2kurs_2_sem\Kursach\Kursovaya\Kursovaya\images\refresh.png" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            
            <ItemsControl x:Name="imageListView"  Margin="0,200,0,0" Background="{x:Null}" Width="1600" Height="auto" >
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="5" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
        
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid MouseUp="GridClicked">
                            <Image Source="C:\labi_2kurs_2_sem\Kursach\Kursovaya\Kursovaya\image_paths\backfoto.png" Width="300" Height="400" />
                            <Image Source="{Binding ImagePaths[0]}" Width="230" Height="313" />
                            <Button Click="Edit_Image_Click"  Width="50" Height="50" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="130,430,0,0">
                                <Image Source="C:\labi_2kurs_2_sem\Kursach\Kursovaya\Kursovaya\images\edit.png"></Image>
                            </Button>
                            <Button Click="Delete_Image_Click"  Width="50" Height="50" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="240,430,0,0">
                                <Image Source="C:\labi_2kurs_2_sem\Kursach\Kursovaya\Kursovaya\images\korz.png"></Image>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</Window>
